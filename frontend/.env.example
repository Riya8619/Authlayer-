# Base URL of the AuthLayer backend API (no trailing slash).
# Required. The app has no localhost fallback in production, so scans will
# fail with a clear "not configured" error until this is set.
# Example: https://api.authlayer.com
NEXT_PUBLIC_API_BASE=

# Public site URL, used for SEO metadata (Open Graph, canonical URL, etc).
NEXT_PUBLIC_SITE_URL=https://your-domain.example
