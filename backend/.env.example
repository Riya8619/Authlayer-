# --- App ---
APP_NAME=AuthLayer API
ENVIRONMENT=production
PORT=8000

# --- Database (Neon PostgreSQL) ---
# Get this from your Neon project dashboard. Must include sslmode=require.
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require&channel_binding=require

# --- CORS ---
# Comma-separated list of allowed frontend origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.example.com

# --- Provider selection ---
TEXT_DETECTION_PROVIDER=huggingface
URL_CHECK_PROVIDER=google_safe_browsing

# --- Provider API keys ---
HUGGINGFACE_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=

# --- HTTP client behavior ---
PROVIDER_TIMEOUT_SECONDS=15
